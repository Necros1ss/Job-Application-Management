{
  "name": "hr-management-app",
  "private": true,
  "version": "1.0.0",
  "description": "Full-cycle HR Management and Job Application Tracker - React, Vite, Express.js, PostgreSQL",
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n BACKEND,FRONTEND -c cyan,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:full": "npm run db:up && npm run dev",
    "dev:backend": "nodemon backend/src/server.js",
    "dev:frontend": "vite --config frontend/vite.config.js",
    "build": "npm run build:frontend",
    "build:frontend": "vite build --config frontend/vite.config.js",
    "preview:frontend": "vite preview --config frontend/vite.config.js",
    "start:backend": "node backend/src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "install:all": "npm install",
    "db:up": "docker compose -f docker-compose.yml up -d db",
    "db:down": "docker compose -f docker-compose.yml down",
    "db:reset": "docker compose -f docker-compose.yml down -v && docker compose -f docker-compose.yml up -d db",
    "db:logs": "docker compose -f docker-compose.yml logs -f db",
    "migrate": "npm run migrate --prefix backend",
    "db:migrate": "npm run db:up && npm run migrate",
    "lint:frontend": "cd frontend && npx eslint src --ext .js,.jsx",
    "smoke:backend": "node -e \"const http=require('http');http.get('http://localhost:5000/api/health',(r)=>{let d='';r.on('data',c=>d+=c);r.on('end',()=>{console.log('Status:',r.statusCode);console.log('Body:',d);process.exit(r.statusCode===200?0:1)})}).on('error',e=>{console.error('Backend not reachable:',e.message);process.exit(1)})\""
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "nodemon": "^3.1.7",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.0"
  }
}

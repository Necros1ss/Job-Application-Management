# Database
DATABASE_URL=postgresql://postgres:postgres123@localhost:5433/job_tracker

# JWT
JWT_SECRET=replace-with-a-random-access-token-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-random-refresh-secret-at-least-32-chars

# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=replace-with-smtp-user
MAIL_PASS=replace-with-smtp-password
MAIL_FROM=Job Tracker <noreply@example.com>

# AI screening
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash

# File upload
UPLOAD_DIR=./uploads/cv
MAX_FILE_SIZE_MB=20
